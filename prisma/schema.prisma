// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // bcrypt加密后的密码
  name      String   // 显示名称
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  favorites Favorite[]

  @@index([username])
}

model Article {
  id           String           @id @default(uuid())
  title        String
  author       String
  createdAt    DateTime         @default(now())
  importance   String           // 'low', 'medium', 'high'
  views        Int              @default(0)
  content      String           // 富文本内容（HTML）
  updatedAt    DateTime         @updatedAt
  reviewStatus String           @default("pending_review") // 'pending_review', 'approved', 'rejected'
  rejectReason String?          // 驳回理由
  comments     Comment[]
  tags         ArticleTag[]
  versions     ArticleVersion[]
  favorites    Favorite[]

  @@index([title])
  @@index([createdAt])
  @@index([author])
  @@index([reviewStatus])
}

model ArticleVersion {
  id          String   @id @default(uuid())
  articleId   String
  versionNumber Int
  title       String
  content     String
  author      String
  importance  String
  modifiedBy  String
  changeSummary String?
  createdAt   DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, versionNumber])
  @@index([articleId])
  @@index([articleId, versionNumber])
  @@index([createdAt])
}

model Tag {
  id          String        @id @default(uuid())
  name        String        @unique
  color       String        @default("#1890ff")
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  articles    ArticleTag[]

  @@index([name])
}

model ArticleTag {
  id        String   @id @default(uuid())
  articleId String
  tagId     String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([articleId, tagId])
  @@index([articleId])
  @@index([tagId])
}

model Comment {
  id        String   @id @default(uuid())
  articleId String
  nickname  String
  email     String
  content   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([status])
  @@index([createdAt])
}

model MediaFolder {
  id        String      @id @default(uuid())
  name      String
  parentId  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  parent    MediaFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  MediaFolder[] @relation("FolderHierarchy")
  files     MediaFile[]

  @@index([parentId])
  @@index([name])
}

model MediaFile {
  id        String   @id @default(uuid())
  filename  String   // 原始文件名
  storedName String  // 存储的文件名（UUID）
  url       String   // 访问URL
  mimeType  String   // MIME类型
  size      Int      // 文件大小（字节）
  folderId  String?  // 所在文件夹ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folder    MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([folderId])
  @@index([filename])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  type      String   @default("review") // 'review'
  isRead    Boolean  @default(false)
  articleId String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
  @@index([articleId])
  @@index([createdAt])
}
